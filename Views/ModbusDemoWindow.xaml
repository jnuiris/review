<Window x:Class="IPWorkbench.Views.ModbusDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Modbus TCP"
        Height="520" Width="560"
        MinHeight="420" MinWidth="480"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Closing="Window_Closing">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top" Text="Modbus TCP 主站（连接本机从站）"
                   FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,16"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="关闭" Width="100" Height="36" Padding="12,0" Click="CloseButton_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 连接 -->
                <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="连接" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Grid.Column="0" Text="主机" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox x:Name="HostText" Grid.Row="0" Grid.Column="1" Text="127.0.0.1" Margin="0,0,12,8" Height="28" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="端口" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            <TextBox x:Name="PortText" Grid.Row="0" Grid.Column="3" Text="502" Margin="0,0,0,8" Height="28" VerticalContentAlignment="Center"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="站号" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="SlaveIdText" Grid.Row="1" Grid.Column="1" Text="1" Width="80" HorizontalAlignment="Left" Height="28" VerticalContentAlignment="Center"/>
                            <StackPanel Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="ConnectButton" Content="连接" Width="88" Height="32" Margin="0,0,8,0" Click="ConnectButton_Click"/>
                                <Button x:Name="DisconnectButton" Content="断开" Width="88" Height="32" IsEnabled="False" Click="DisconnectButton_Click"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="StatusText" Text="未连接" Foreground="#666" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 读保持寄存器 -->
                <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="读保持寄存器（功能码 0x03）" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="起始地址" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="ReadStartText" Grid.Column="1" Text="0" Height="28" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="数量" VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <TextBox x:Name="ReadCountText" Grid.Column="3" Text="10" Height="28" VerticalContentAlignment="Center"/>
                            <Button x:Name="ReadButton" Grid.Column="4" Content="读取" Width="88" Height="32" HorizontalAlignment="Right"
                                    IsEnabled="False" Click="ReadButton_Click"/>
                        </Grid>
                        <TextBox x:Name="ReadResultText" Margin="0,12,0,0" MinHeight="72" TextWrapping="Wrap" AcceptsReturn="True"
                                 IsReadOnly="True" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- 写单个保持寄存器 -->
                <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16">
                    <StackPanel>
                        <TextBlock Text="写单个保持寄存器（功能码 0x06）" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="72"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="地址" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBox x:Name="WriteAddrText" Grid.Column="1" Text="0" Height="28" VerticalContentAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="值 0–65535" VerticalAlignment="Center" Margin="12,0,8,0"/>
                            <TextBox x:Name="WriteValueText" Grid.Column="3" Text="0" Height="28" VerticalContentAlignment="Center"/>
                            <Button x:Name="WriteButton" Grid.Column="4" Content="写入" Width="88" Height="32" HorizontalAlignment="Right"
                                    IsEnabled="False" Click="WriteButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
