<Window x:Class="IPWorkbench.Views.OpcUaDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OPC UA"
        Height="520" Width="640"
        MinHeight="440" MinWidth="520"
        WindowStartupLocation="CenterOwner"
        Background="#F5F5F5"
        Closing="Window_Closing">
    <DockPanel Margin="20">
        <TextBlock DockPanel.Dock="Top" Text="OPC UA 客户端（连接本机模拟服务器）"
                   FontSize="18" FontWeight="SemiBold" Foreground="#333" Margin="0,0,0,12"/>

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="关闭" Width="100" Height="36" Click="CloseButton_Click"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="连接" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="服务端点（URI）" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="EndpointText" Text="opc.tcp://127.0.0.1:4840" Height="28" VerticalContentAlignment="Center"/>
                        <TextBlock Text="安全策略：无加密（None），与多数本地模拟器默认一致。" FontSize="11" Foreground="#888" Margin="0,8,0,0" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <Button x:Name="ConnectButton" Content="连接" Width="88" Height="32" Margin="0,0,8,0" Click="ConnectButton_Click"/>
                            <Button x:Name="DisconnectButton" Content="断开" Width="88" Height="32" IsEnabled="False" Click="DisconnectButton_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="StatusText" Text="未连接" Foreground="#666" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="6" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="读变量（Value 属性）" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="NodeId（文本）" FontSize="12" Foreground="#666" Margin="0,0,0,4"/>
                        <TextBox x:Name="NodeIdText" Height="28" VerticalContentAlignment="Center"/>
                        <TextBlock Text="默认 ns=0;i=2258 为 OPC UA 标准「当前服务器时间」，一般模拟器均提供。" FontSize="11" Foreground="#888" Margin="0,6,0,8" TextWrapping="Wrap"/>
                        <Button x:Name="ReadButton" Content="读取" Width="88" Height="32" HorizontalAlignment="Left" IsEnabled="False" Click="ReadButton_Click"/>
                        <TextBox x:Name="ReadResultText" Margin="0,12,0,0" MinHeight="80" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" FontFamily="Consolas" FontSize="13"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
